[Unit]
Description=Nuxt Production Application
After=network.target

[Service]
Type=simple

User=deploy
Group=deploy

WorkingDirectory=/opt/nuxt-app

Environment=NODE_ENV=production
Environment=PORT=3000

ExecStart=/usr/bin/node .output/server/index.mjs

Restart=always
RestartSec=5

StandardOutput=append:/var/log/nuxt-app/out.log
StandardError=append:/var/log/nuxt-app/error.log

LimitNOFILE=65535

[Install]
WantedBy=multi-user.target